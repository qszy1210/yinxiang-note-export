# 印象笔记 Developer Token 配置
# 获取地址: https://app.yinxiang.com/api/DeveloperToken.action

# Developer Token (必填)
EVERNOTE_TOKEN=your_developer_token_here

# NoteStore URL (必填)
# 格式类似: https://app.yinxiang.com/shard/s1/notestore
EVERNOTE_NOTESTORE_URL=your_notestore_url_here

# 服务端口 (可选, 默认 3000)
PORT=3000
